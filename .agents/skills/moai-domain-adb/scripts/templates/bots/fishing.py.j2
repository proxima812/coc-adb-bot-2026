    # ===================================================================
    # Fishing Loop
    # ===================================================================

    def _fishing_loop(self) -> int:
        """Execute main fishing loop.

        Returns:
            int: Number of fish caught

        TODO: Customize fishing loop parameters:
        - Maximum attempts
        - Bait usage
        - Target fish types
        """
        logging.info("Starting fishing loop...")
        fish_caught = 0
        max_attempts = 20

        for attempt in range(max_attempts):
            if not self._check_bait_available():
                logging.info("No bait remaining")
                break

            if self._execute_single_catch():
                fish_caught += 1
                logging.info(f"Caught fish {fish_caught}/{max_attempts}")
            else:
                logging.debug(f"Fishing attempt {attempt + 1} failed")

            sleep(2)

        return fish_caught

