    # ===================================================================
    # Farming Loop
    # ===================================================================

    def _farming_loop(self) -> int:
        """Execute main farming loop.

        Returns:
            int: Number of farming runs completed

        TODO: Customize farming parameters:
        - Maximum runs
        - Energy management
        - Auto-refill settings
        """
        logging.info("Starting farming loop...")
        runs_completed = 0
        max_runs = 50

        for run in range(max_runs):
            if not self._check_energy_available():
                logging.info("Energy depleted")

                # Try to refill energy
                if not self._refill_energy():
                    break

            if self._execute_farming_run():
                runs_completed += 1
                logging.info(f"Completed run {runs_completed}/{max_runs}")
            else:
                logging.warning(f"Run {run + 1} failed")
                break

            # Small delay between runs
            sleep(2)

        return runs_completed

