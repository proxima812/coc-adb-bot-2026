    # ===================================================================
    # Dungeon Progression
    # ===================================================================

    def _dungeon_loop(self) -> int:
        """Execute dungeon floor progression.

        Returns:
            int: Number of floors cleared

        TODO: Customize dungeon loop:
        - Floor limit
        - Auto-exit conditions
        - Boss detection
        """
        logging.info("Starting dungeon progression...")
        floors_cleared = 0
        max_floors = 10

        for floor in range(max_floors):
            logging.info(f"Floor {floor + 1}/{max_floors}")

            if not self._clear_floor():
                logging.info(f"Failed to clear floor {floor + 1}")
                break

            floors_cleared += 1

            # Check if reached boss or exit
            if self._check_boss_floor() or self._check_exit_available():
                logging.info("Reached final floor or exit point")
                break

        return floors_cleared

    def _clear_floor(self) -> bool:
        """Clear current dungeon floor.

        Returns:
            bool: True if floor cleared

        TODO: Implement floor clearing:
        - Navigate through rooms
        - Battle enemies
        - Collect treasures
        - Handle traps/puzzles
        """
        try:
            # Move to next room
            if not self._move_to_next_room():
                return False

            # Battle enemies
            if not self._clear_room_enemies():
                return False

            # Collect treasure
            self._collect_treasure()

            # Check for floor completion
            return self._check_floor_complete()

        except GameTimeoutError:
            return False

    def _move_to_next_room(self) -> bool:
        """Navigate to next room in dungeon.

        Returns:
            bool: True if moved successfully

        TODO: Implement room navigation:
        - Detect available paths
        - Choose optimal path
        - Handle locked doors
        """
        logging.debug("Moving to next room...")

        try:
            # Find next room indicator
            next_room = self.wait_for_template(
                "dungeon/next_room.png",
                timeout=self.MIN_TIMEOUT,
                timeout_message="Next room not found"
            )
            self.tap(next_room)
            sleep(2)

            return True

        except GameTimeoutError:
            return False

    def _clear_room_enemies(self) -> bool:
        """Battle and clear room enemies.

        Returns:
            bool: True if enemies cleared

        TODO: Implement enemy battle:
        - Detect enemy presence
        - Execute battle
        - Handle multiple enemy waves
        """
        logging.debug("Clearing room enemies...")

        try:
            # Check for enemies
            enemy = self.game_find_template_match("dungeon/enemy.png")

            if not enemy:
                logging.debug("No enemies in room")
                return True

            # Start battle
            battle_btn = self.wait_for_template(
                "battle/battle.png",
                timeout=self.MIN_TIMEOUT,
                timeout_message="Battle button not found"
            )
            self.tap(battle_btn)
            sleep(2)

            # Wait for battle completion
            result = self.wait_for_template(
                "battle/victory_rewards.png",
                timeout=120,
                timeout_message="Battle timeout"
            )

            # Dismiss results
            for _ in range(3):
                self.tap(Point(540, 1900))
                sleep(1)

            return result is not None

        except GameTimeoutError:
            return False

