        logging.debug("Collecting treasure...")

        try:
            # Find treasure chest
            chest = self.game_find_template_match("dungeon/chest.png")

            if chest:
                self.tap(chest)
                sleep(2)

                # Open chest
                open_btn = self.wait_for_template(
                    "dungeon/open_chest.png",
                    timeout=self.MIN_TIMEOUT
                )
                self.tap(open_btn)
                sleep(2)

                # Dismiss rewards
                self.tap(Point(540, 1900))
                sleep(1)

        except GameTimeoutError:
            pass

