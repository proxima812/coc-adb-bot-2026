class {{ class_name }}(AFKJourneyBase):
    """{{ game_name }} Arena bot for PvP automation."""

    @register_command(
        name="{{ game_name }} Arena",
        gui=GUIMetadata(
            label="{{ game_name }} Arena",
            category=AFKJCategory.GAME_MODES,
        ),
    )
    def run_arena(self) -> None:
        """Execute arena battles automation."""
        logging.info("Starting {{ game_name }} Arena bot...")
        self.start_up(device_streaming=False)

        try:
            self._enter_arena()
        except GameTimeoutError:
            logging.error("Failed to enter arena")
            return

        # Execute free attempts
        attempts_completed = 0
        max_attempts = 5

        for attempt in range(max_attempts):
            if self._check_no_attempts():
                logging.info(f"Free attempts exhausted after {attempts_completed} battles")
                break

            if self._execute_arena_battle():
                attempts_completed += 1
                logging.info(f"Completed arena battle {attempts_completed}/{max_attempts}")
            else:
                logging.warning(f"Arena battle {attempt + 1} failed")
                break

        # Claim additional attempts if available
        self._claim_bonus_attempts()

        logging.info(f"{{ game_name }} Arena finished: {attempts_completed} battles completed")

