    # ===================================================================
    # Reward Collection
    # ===================================================================

    def _claim_quest_reward(self) -> bool:
        """Claim quest completion reward.

        Returns:
            bool: True if reward claimed

        TODO: Customize reward claim logic
        """
        logging.debug("Claiming quest reward...")

        try:
            claim_btn = self.wait_for_template(
                "quests/claim_button.png",
                timeout=self.MIN_TIMEOUT,
                timeout_message="Claim button not found"
            )
            self.tap(claim_btn)
            sleep(2)

            # Dismiss reward popup
            self.tap(Point(540, 1900))
            sleep(1)

            return True

        except GameTimeoutError:
            return False

    def _claim_daily_rewards(self) -> None:
        """Claim additional daily rewards.

        TODO: Implement bonus reward collection:
        - Daily login rewards
        - Milestone rewards
        - Achievement rewards
        """
        logging.info("Claiming daily rewards...")

        # Check for reward chest
        try:
            reward_chest = self.game_find_template_match(
                "quests/reward_chest.png"
            )

            if reward_chest:
                self.tap(reward_chest)
                sleep(2)

                # Claim all rewards
                claim_all = self.wait_for_template(
                    "quests/claim_all.png",
                    timeout=self.MIN_TIMEOUT
                )
                self.tap(claim_all)
                sleep(2)

        except GameTimeoutError:
            logging.debug("No daily rewards available")

    def _return_to_quest_menu(self) -> None:
        """Return to quest menu after quest activity.

        TODO: Customize return navigation
        """
        logging.debug("Returning to quest menu...")

        # Tap back button multiple times
        for _ in range(3):
            try:
                back_btn = self.wait_for_template(
                    "back.png",
                    timeout=self.MIN_TIMEOUT
                )
                self.tap(back_btn)
                sleep(1)
            except GameTimeoutError:
                break
