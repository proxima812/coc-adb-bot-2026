            )
            self.tap(battle_btn)
            sleep(2)

            # Wait for battle completion
            self.wait_for_template(
                "battle/victory_rewards.png",
                timeout=120,
                timeout_message="Battle timeout"
            )

            # Return to quest menu
            self._return_to_quest_menu()

            return True

        except GameTimeoutError:
