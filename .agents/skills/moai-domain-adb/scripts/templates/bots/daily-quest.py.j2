        ),
    )
    def run_daily_quests(self) -> None:
        """Execute daily quest automation."""
        logging.info("Starting {{ game_name }} Daily Quests bot...")
        self.start_up(device_streaming=False)

        try:
            self._open_quest_menu()
            quests_completed = self._complete_all_quests()
            self._claim_daily_rewards()

            logging.info(
                f"{{ game_name }} Daily Quests completed: {quests_completed} quests"
            )

        except GameTimeoutError as e:
            logging.error(f"Daily quest error: {e}")
            return

